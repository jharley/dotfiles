export DO_NOT_TRACK=1

if [[ -e $(which gpg 2>/dev/null) ]]; then
  export GPG_TTY=$(tty)
fi

if [ ! -f "$HOME/.bash" ]; then
  for f in ~/.bash/*.sh; do source $f; done

  # 'local' environment variables not managed by git (API tokens, et cetera)
  [ -f ~/.bashrc.local ] && source ~/.bashrc.local
fi
